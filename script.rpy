    import random
    # Функция для проверки создания переменной (РАБОТАЕТ, НЕ ТРОГАЙ!!!)
    def check_code_l1(user_input, expected_var_name, expected_value):
        try:
            # Создаем изолированное пространство для выполнения кода
            namespace = {}
            exec(user_input, {}, namespace)
            
            # Проверяем, появилась ли переменная и верно ли ее значение
            if expected_var_name in namespace and namespace[expected_var_name] == expected_value:
                return True
            return False
        except:
            # Если код с ошибкой (например, синтаксической), возвращаем False
            return False
    def get_random_var():
        names = [
        # 1. Классический Snake Case (PEP 8)
        "user_session", "data_payload", "request_body", "file_path", "status_code",
        "is_active", "total_price", "created_at", "updated_at", "meta_data",
        "buffer_size", "max_limit", "min_offset", "error_message", "retry_count",
        "api_endpoint", "db_connection", "auth_token", "page_index", "items_per_page",

        # 2. Переменные с цифрами (не в начале)
        "point1", "point2", "version2_alpha", "step_01", "block_1024",
        "level_5_boss", "id_888", "temp_v3", "node_4", "route_66",

        # 3. Названия с одинарным подчеркиванием в начале (Protected)
        "_internal_var", "_cache", "_hidden_state", "_temp_ref", "_config_data",
        "_private_key", "_debug_mode", "_raw_output", "_logger_inst", "_instance",

        # 4. Названия с двойным подчеркиванием в начале (Private/Mangling)
        "__secret", "__base_attr", "__secure_link", "__init_params", "__core_logic",
        "__internal_hash", "__encryption_salt", "__mapping", "__strict_mode", "__id",

        # 5. Константы (Screaming Snake Case)
        "DEFAULT_TIMEOUT", "MAX_RETRIES", "BASE_URL", "COLOR_RED", "PI_CONSTANT",
        "LOG_LEVEL", "ENV_PRODUCTION", "BUFFER_CAPACITY", "PAGE_SIZE", "DB_NAME",

        # 6. Варианты с подчеркиванием в конце (во избежание конфликтов)
        "class_", "type_", "list_", "id_", "input_",
        "format_", "object_", "data_", "value_", "mode_",

        # 7. Короткие и специальные (но валидные)
        "_", "x", "y", "i", "j", "df", "msg", "ref", "res", "req",

        # 8. Смешанный регистр (допустим, хоть и не рекомендован для переменных)
        "itemsBundle", "userData", "getParams", "currentTask", "lastEvent"
        ]
        return random.choice(names)

