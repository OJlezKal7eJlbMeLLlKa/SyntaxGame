#         $ q_text = h_question_l3(number).format(var=current_var)
#         $ helper_question(q_text)
#         $ ans = renpy.input(">>>")
#
#         # Для 3 уровня (условия) используем логику check_code_l2,
#         # но добавим проверку на наличие слова 'if'
#         if "if" in ans and check_code_l2(ans, current_var):
#             jump success_action
#         else:
#             jump fail_action

# Эти метки должны быть ВНЕ блока level_loop (на одном уровне отступа с ним)
label success_action:
    $ number += 1
    $ points += 10
    $ h_msg = get_h_right_phrase()
    h happy "[h_msg]"

    $ b_msg = get_b_right_phrase()
    show buggy at right # Или твоя зона
    b "[b_msg]"
    hide buggy
    jump level_loop

label fail_action:
    $ errors += 1
    with hpunch
    $ h_msg = get_h_fail_phrase()
    h confused "[h_msg]"

    $ b_msg = get_b_fail_phrase()
    show buggy evil at right
    b "[b_msg] (Ошибок: [errors]/3)"
    hide buggy
    jump level_loop

# КОНЦОВКИ
label bad_ending:
    scene bg boom
    show buggy at center
    b "Я же говорил! Твой код вызвал переполнение стека в моей голове! БУМ!"
    "Плохая концовка: Вы сломали наставника."
    return

label win_ending:
    scene bg office
    "Прошло 10 лет..."
    "Ты — ведущий разработчик. Твой кофе стоит больше, чем твой первый компьютер."
    "Интересный факт: каждый программист - это тот, кто превращает кофеин в код, который почему-то работает только по четвергам'."
    "Поздравляем! Ты прошел игру!."
    "Хорошая концовка"
    return

# СПРАВОЧНИК
label tutorial_label:
    h "Краткий курс молодого бойца:"
    "1. Присваивание: name = 10"
    "2. Типы данных: int('5') делает число, str(5) делает текст."
    "3. Ввод: input(). Чтобы получить число, пиши int(input())."
    "4. Множественный ввод: a, b = map(int, input().split()) — это магия для ввода двух чисел через пробел."
    h "Запомнил? Теперь в бой!"
    jump level_loop